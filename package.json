{
  "name": "ajicore",
  "version": "1.0.0",
  "description": "A comprehensive backend platform for service businesses — scheduling, invoicing, bookkeeping, inventory, and fleet tracking.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:legacy": "node --test --test-concurrency=1",
    "export:ai-api": "node scripts/export-ai-api.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "service-business",
    "scheduling",
    "invoicing",
    "fleet",
    "inventory"
  ],
  "author": "Ajicore Team",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/storage": "^7.0.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "1.4.5-lts.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "prisma": "^6.19.2"
  }
}
