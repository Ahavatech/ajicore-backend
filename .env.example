# Required for all environments
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/ajicore
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# AI Service
AI_SERVICE_URL=http://localhost:4000
AI_SERVICE_API_KEY=your_api_key

# Internal API
INTERNAL_API_KEY=change-me-to-random-string

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# Database (optional, for direct connection)
DIRECT_URL=postgresql://user:password@localhost:5432/ajicore

# Redis (optional, for distributed rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Session (optional, for CSRF protection)
SESSION_SECRET=change-me-to-random-string